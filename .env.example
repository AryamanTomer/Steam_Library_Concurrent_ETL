# Required to download the Steam catalog (IStoreService/GetAppList) and for SteamConcurrent.py
STEAM_API_KEY=

# Optional: do not auto-download the full catalog on server start (default: off).
# Without this, only an existing cache file is loaded — use the Download catalog button.
# STEAM_AUTO_DOWNLOAD_CATALOG=0

# Optional: cap how many apps to download (faster). Example: 20000. Leave unset for full catalog.
# STEAM_CATALOG_MAX_APPS=

# Optional: catalog JSON cache path (default: ./data/steam_catalog_apps.json)
# STEAM_CATALOG_CACHE_PATH=

# Skip any catalog load on startup (1/true/yes)
# STEAM_SKIP_CATALOG_LOAD=0

# Parallel workers for GetNumberOfCurrentPlayers (default 32)
# STEAM_FETCH_WORKERS=32

# --- SteamConcurrent.py only (your library → CSV) ---
# STEAM_ID64=
